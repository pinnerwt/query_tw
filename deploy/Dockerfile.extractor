FROM golang:1.22-alpine AS gobuilder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/extractor ./cmd/extractor

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
WORKDIR /app
COPY --from=gobuilder /out/extractor ./extractor
COPY fixtures /app/fixtures
ENTRYPOINT ["./extractor"]
